@model Book_characteristics

<h2>Confirm Delete</h2>

<div>
    <h4>Are you sure you want to delete this book?</h4>
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">@Model.Author</dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category</dd>
    </dl>

    @using (Html.BeginForm("Delete", "Home", FormMethod.Post))
    {
        @Html.HiddenFor(x => x.Id)
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="AllBooks" class="btn btn-secondary">Cancel</a>
    }
</div>
