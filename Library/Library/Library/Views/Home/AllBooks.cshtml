@model List<Book_characteristics>

@{
    ViewData["Title"] = "All Books";
}

<div class="container-fluid">
    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-4">
                <i class="fas fa-book"></i>
                Library Collection
            </h1>
            <p class="lead text-muted">
                @if (ViewBag.FilteredBooks != ViewBag.TotalBooks)
                {
                    <span>Showing @ViewBag.FilteredBooks of @ViewBag.TotalBooks books</span>
                }
                else
                {
                    <span>Discover and explore our collection of @ViewBag.TotalBooks books</span>
                }
            </p>
        </div>
        <div class="col-md-4 text-end">
            @if (ViewBag.IsLoggedIn)
            {
                <div class="mb-2">
                    <span class="badge bg-primary">
                        <i class="fas fa-user"></i>
                        Logged In
                    </span>
                    @if (ViewBag.IsAdmin)
                    {
                        <span class="admin-badge ms-2">
                            <i class="fas fa-crown"></i>
                            Administrator
                        </span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="search-filter-section mb-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="get" asp-action="AllBooks" asp-controller="Home" class="row g-3">
                    <div class="col-md-6">
                        <label for="searchTerm" class="form-label">
                            <i class="fas fa-search"></i>
                            Search Books
                        </label>
                        <input type="text" 
                               class="form-control" 
                               id="searchTerm" 
                               name="searchTerm" 
                               value="@ViewBag.SearchTerm" 
                               placeholder="Search by title, author, category, or description..."
                               autocomplete="off">
                    </div>
                    <div class="col-md-4">
                        <label for="category" class="form-label">
                            <i class="fas fa-filter"></i>
                            Filter by Category
                        </label>
                        <select class="form-select" id="category" name="category">
                            <option value="">All Categories</option>
                            @foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat" selected="@(ViewBag.SelectedCategory == cat)">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="btn-group w-100" role="group">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-search"></i>
                                Search
                            </button>
                            <a href="@Url.Action("AllBooks", "Home")" class="btn btn-outline-secondary">
                                <i class="fas fa-times"></i>
                                Clear
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Search Results Info -->
    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm) || !string.IsNullOrEmpty(ViewBag.SelectedCategory))
    {
        <div class="search-results-info mb-3">
            <div class="alert alert-info d-flex align-items-center">
                <i class="fas fa-info-circle me-2"></i>
                <div>
                    <strong>Search Results:</strong>
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                    {
                        <span>Searching for "<strong>@ViewBag.SearchTerm</strong>"</span>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.SelectedCategory))
                    {
                        <span>in category "<strong>@ViewBag.SelectedCategory</strong>"</span>
                    }
                    <span>- Found @ViewBag.FilteredBooks result(s)</span>
                </div>
            </div>
        </div>
    }

    <!-- Admin Controls -->
    @if (ViewBag.IsAdmin)
    {
        <div class="admin-controls">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h5 class="mb-0">
                        <i class="fas fa-tools"></i>
                        Administrator Controls
                    </h5>
                    <small class="text-muted">Manage the library collection</small>
                </div>
                <div class="col-md-4 text-end">
                    <a asp-action="AddBook" asp-controller="Home" class="btn btn-add">
                        <i class="fas fa-plus"></i>
                        Add New Book
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Books Grid -->
    @if (Model.Any())
    {
        <div class="books-grid">
            @foreach (var book in Model)
            {
                <div class="card book-card h-100">
                    <div class="position-relative">
                        <img src="@book.CoverImage" class="card-img-top book-cover" alt="@book.Title Cover" 
                             onerror="this.src='https://via.placeholder.com/300x400/e9ecef/6c757d?text=No+Image'">
                        <div class="position-absolute top-0 end-0 m-2">
                            <span class="book-category">@book.Category</span>
                        </div>
                    </div>
                    
                    <div class="card-body d-flex flex-column">
                        <h5 class="book-title">@book.Title</h5>
                        <p class="book-author">by @book.Author</p>
                        
                        <div class="book-meta mb-2">
                            <small class="text-muted">
                                <i class="fas fa-calendar"></i> @book.YearPublished
                                <span class="mx-2">•</span>
                                <i class="fas fa-file-alt"></i> @book.Pages pages
                            </small>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(book.Description))
                        {
                            <p class="card-text text-muted small flex-grow-1">
                                @(book.Description.Length > 100 ? book.Description.Substring(0, 100) + "..." : book.Description)
                            </p>
                        }
                        
                        <div class="mt-auto">
                            <div class="row g-2">
                                <div class="col-6">
                                    <a asp-action="Download" asp-controller="Home" asp-route-id="@book.Id" 
                                       class="btn btn-success w-100">
                                        <i class="fas fa-download"></i>
                                        Download
                                    </a>
                                </div>
                                <div class="col-6">
                                    <a asp-action="Details" asp-controller="Home" asp-route-id="@book.Id" 
                                       class="btn btn-outline-primary w-100">
                                        <i class="fas fa-eye"></i>
                                        View More
                                    </a>
                                </div>
                                
                                @if (ViewBag.IsAdmin)
                                {
                                    <div class="col-6 mt-2">
                                        <a asp-action="Edit" asp-controller="Home" asp-route-id="@book.Id" 
                                           class="btn btn-edit w-100">
                                            <i class="fas fa-edit"></i>
                                            Edit
                                        </a>
                                    </div>
                                    <div class="col-6 mt-2">
                                        <button type="button" class="btn btn-delete w-100" 
                                                onclick="confirmDelete(@book.Id, '@book.Title')">
                                            <i class="fas fa-trash"></i>
                                            Delete
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm) || !string.IsNullOrEmpty(ViewBag.SelectedCategory))
            {
                <i class="fas fa-search fa-5x text-muted mb-3"></i>
                <h3 class="text-muted">No Books Found</h3>
                <p class="text-muted">
                    No books match your search criteria. Try adjusting your search terms or filters.
                </p>
                <a href="@Url.Action("AllBooks", "Home")" class="btn btn-primary">
                    <i class="fas fa-arrow-left"></i>
                    View All Books
                </a>
            }
            else
            {
                <i class="fas fa-book-open fa-5x text-muted mb-3"></i>
                <h3 class="text-muted">No Books Available</h3>
                <p class="text-muted">The library collection is empty.</p>
                @if (ViewBag.IsAdmin)
                {
                    <a asp-action="AddBook" asp-controller="Home" class="btn btn-add">
                        <i class="fas fa-plus"></i>
                        Add the First Book
                    </a>
                }
            }
        </div>
    }
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle"></i>
                    Confirm Deletion
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the book "<span id="bookTitle"></span>"?</p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i>
                    Cancel
                </button>
                <form id="deleteForm" method="post" style="display: inline;">
                    <button type="submit" class="btn btn-delete">
                        <i class="fas fa-trash"></i>
                        Delete Book
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(bookId, bookTitle) {
            document.getElementById('bookTitle').textContent = bookTitle;
            document.getElementById('deleteForm').action = '@Url.Action("Delete", "Home")/' + bookId;
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            deleteModal.show();
        }

        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);

        // Enhanced search functionality
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchTerm');
            const categorySelect = document.getElementById('category');
            const searchForm = document.querySelector('form[asp-action="AllBooks"]');

            // Auto-submit on category change
            categorySelect.addEventListener('change', function() {
                searchForm.submit();
            });

            // Add search input enhancements
            searchInput.addEventListener('input', function() {
                // Add visual feedback for active search
                if (this.value.length > 0) {
                    this.classList.add('border-primary');
                } else {
                    this.classList.remove('border-primary');
                }
            });

            // Handle Enter key in search input
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    searchForm.submit();
                }
            });

            // Focus search input if there's a search term
            if (searchInput.value.length > 0) {
                searchInput.classList.add('border-primary');
            }
        });
    </script>
}
