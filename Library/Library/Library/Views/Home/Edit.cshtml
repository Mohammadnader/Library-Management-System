@model Book_characteristics

<h2>Edit Book</h2>

@using (Html.BeginForm("Edit", "Home", FormMethod.Post))
{
    @Html.ValidationSummary(false, "", new { @class = "text-danger" })

    <div>
        @Html.LabelFor(x => x.Title)
        @Html.TextBoxFor(x => x.Title, new { @class = "form-control" })
        @Html.ValidationMessageFor(x => x.Title)
    </div>

    <div>
        @Html.LabelFor(x => x.Author)
        @Html.TextBoxFor(x => x.Author, new { @class = "form-control" })
        @Html.ValidationMessageFor(x => x.Author)
    </div>

    <div>
        @Html.LabelFor(x => x.Category)
        @Html.TextBoxFor(x => x.Category, new { @class = "form-control" })
        @Html.ValidationMessageFor(x => x.Category)
    </div>

    <div>
        @Html.LabelFor(x => x.YearPublished)
        @Html.TextBoxFor(x => x.YearPublished, new { @class = "form-control", type = "number" })
        @Html.ValidationMessageFor(x => x.YearPublished)
    </div>

    <div>
        @Html.LabelFor(x => x.Description)
        @Html.TextAreaFor(x => x.Description, new { @class = "form-control" })
    </div>

    <div>
        @Html.LabelFor(x => x.Pages)
        @Html.TextBoxFor(x => x.Pages, new { @class = "form-control", type = "number" })
        @Html.ValidationMessageFor(x => x.Pages)
    </div>

    <div>
        @Html.LabelFor(x => x.Language)
        @Html.TextBoxFor(x => x.Language, new { @class = "form-control" })
    </div>

    <div>
        @Html.LabelFor(x => x.CoverImage)
        @Html.TextBoxFor(x => x.CoverImage, new { @class = "form-control" })
        @Html.ValidationMessageFor(x => x.CoverImage)
    </div>

    <div>
        @Html.LabelFor(x => x.FilePath)
        @Html.TextBoxFor(x => x.FilePath, new { @class = "form-control" })
        @Html.ValidationMessageFor(x => x.FilePath)
    </div>

    <br />
    <button type="submit" class="btn btn-success">Edit</button>
}
