@model Book_characteristics

@{
    ViewData["Title"] = "Book Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <img src="@Url.Content(Model.CoverImage)" class="card-img-top" alt="@Model.Title Cover" style="height: 400px; object-fit: cover;">
                <div class="card-body text-center">
                    <a href="@Url.Action("Download", new { id = Model.Id })" class="btn btn-success btn-lg mb-2">
                        <i class="fas fa-download"></i> Download Book
                    </a>
                    <a href="@Url.Action("AllBooks")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Library
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">@Model.Title</h2>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Author:</strong></div>
                        <div class="col-sm-9">@Model.Author</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Category:</strong></div>
                        <div class="col-sm-9">
                            <span class="badge badge-primary">@Model.Category</span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Published:</strong></div>
                        <div class="col-sm-9">@Model.YearPublished</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Pages:</strong></div>
                        <div class="col-sm-9">@Model.Pages pages</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Language:</strong></div>
                        <div class="col-sm-9">@Model.Language</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Description:</strong></div>
                        <div class="col-sm-9">@Model.Description</div>
                    </div>

                    @if (ViewBag.IsAdmin)
                    {
                        <hr>
                        <div class="admin-actions">
                            <h5>Admin Actions</h5>
                            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary">
                                <i class="fas fa-edit"></i> Edit Book
                            </a>
                            <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-danger"
                               onclick="return confirm('Are you sure you want to delete this book?')">
                                <i class="fas fa-trash"></i> Delete Book
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .badge-primary {
        background-color: #007bff;
        color: white;
        padding: 0.5em 0.75em;
        border-radius: 0.25rem;
        font-size: 0.875em;
    }

    .admin-actions {
        background-color: #f8f9fa;
        padding: 1rem;
        border-radius: 0.25rem;
        border: 1px solid #dee2e6;
    }

    .card {
        border: none;
        border-radius: 0.5rem;
    }

    .card-header {
        border-radius: 0.5rem 0.5rem 0 0 !important;
    }
</style>
